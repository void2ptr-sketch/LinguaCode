{
  "name": "lingua-code",
  "version": "0.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --no-watch --browsers=ChromeHeadlessNoSandbox",
    "verify": "npm run lint && npm run sync:hanzi && npm run build:prod && npm run test:ci",
    "lint": "ng lint",
    "audit": "npm audit --audit-level=high",
    "format": "prettier --write \"src/**/*.{ts,html,scss,css,json}\" \"*.{json,md,js}\" \"docs/**/*.md\"",
    "sync:hanzi": "node scripts/sync-hanzi-assets.mjs",
    "export:content-seed": "node scripts/content-seed/perl-interview-idea-parser.test.mjs && node scripts/content-seed/perl-interview-tags.test.mjs && node scripts/export-content-seed.mjs",
    "import:perl-idea": "node scripts/import-perl-interview-idea.mjs",
    "import:course-bundle": "node scripts/import-course-bundle.mjs",
    "generate:radicals-course": "node scripts/generate-radicals-course.mjs && node scripts/export-content-seed.mjs",
    "export:course-pdf": "node scripts/export-course-pdf.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.7",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/core": "^22.0.7",
    "@angular/forms": "^22.0.7",
    "@angular/material": "^19.2.19",
    "@angular/platform-browser": "^22.0.7",
    "@angular/platform-browser-dynamic": "^22.0.7",
    "@angular/router": "^22.0.7",
    "highlight.js": "^11.11.1",
    "jspdf": "^4.2.1",
    "marked": "^15.0.12",
    "pdfkit": "^0.19.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.19",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.7",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "21.0.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "hanzi-writer-data": "^2.0.1",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.8.4",
    "typescript": "~5.7.2",
    "typescript-eslint": "8.46.4"
  }
}
