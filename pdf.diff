  async generatePdf(
    courseTitle: string,
    stages: IdeaStage[],
    cardEntries: CardEntry[],
    lessons: readonly Lesson[],
    showHints: boolean,
  ): Promise<Blob> {
    // ... existing code ...

    // --- Страницы карточек (стр. 2+) ---
    for (let i = 0; i < cardEntries.length; i++) {
      const { card, scenarioTitle, lessonTitle, stageIndex } = cardEntries[i]; // ← ДЕСТРУКТУРИЗАЦИЯ
      const pageNum = i + 1;

      doc.addPage();
      this.renderCard(doc, card, scenarioTitle, lessonTitle, courseTitle, pageNum, showHints, stageIndex);
    }

    return doc.output('blob');
  }

