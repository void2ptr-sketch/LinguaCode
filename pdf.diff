  // ... existing code ...

  private collectCardEntries(
    lessons: readonly Lesson[],
    allScenarios: readonly Scenario[],
    allCards: readonly Card[],
    courseLessons: readonly Lesson[], // ← НОВЫЙ ПАРАМЕТР: все уроки курса (для индексов)
  ): CardEntry[] {
    const entries: CardEntry[] = [];
    const scenarioMap = new Map<string, Scenario>();
    for (const s of allScenarios) {
      scenarioMap.set(s.id, s);
    }

    const cardMap = new Map<string, Card>();
    for (const c of allCards) {
      cardMap.set(c.id, c);
    }

    // 📌 Создаём карту: lessonTitle → stageIndex
    const lessonToStageIndex = new Map<string, number>();
    courseLessons.forEach((lesson, i) => {
      lessonToStageIndex.set(lesson.title, i);
    });

    for (const lesson of lessons) {
      for (const scenarioId of lesson.scenarioIds) {
        const scenario = scenarioMap.get(scenarioId);
        if (!scenario) continue;

        const cardSource = scenario.cardSource;
        const cardIds: readonly string[] =
          cardSource.mode === 'fixed' || cardSource.mode === 'snapshot'
            ? cardSource.cardIds
            : [];
        for (const cardId of cardIds) {
          const card = cardMap.get(cardId);
          if (!card) continue;

          entries.push({
            card,
            scenarioTitle: scenario.title,
            lessonTitle: lesson.title,
            stageIndex: lessonToStageIndex.get(lesson.title) ?? 0, // ← ИСПОЛЬЗУЕМ КАРТУ
          });
        }
      }
    }

    return entries;
  }

